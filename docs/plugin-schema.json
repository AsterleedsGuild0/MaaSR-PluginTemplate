{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "plugin-schema.json",
  "title": "MaaStarResonance Plugin",
  "description": "MaaStarResonance 侧载插件元数据配置文件",
  "type": "object",
  "required": ["name", "version", "entry_point"],
  "properties": {
    "$schema": {
      "type": "string",
      "description": "JSON Schema 引用路径"
    },
    "name": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "插件标识名，须为合法的 Python 标识符（小写字母、数字、下划线）"
    },
    "display_name": {
      "type": "string",
      "description": "插件显示名称，可使用中文等可读文本"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+",
      "description": "语义化版本号（SemVer），如 1.0.0"
    },
    "description": {
      "type": "string",
      "description": "插件简要描述"
    },
    "authors": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "插件作者列表"
    },
    "license": {
      "type": "string",
      "description": "许可证标识，如 AGPL-3.0、MIT"
    },
    "pyz_file": {
      "type": "string",
      "pattern": "\\.pyz$",
      "description": "打包后的 .pyz 文件相对路径，如 lib/example_plugin.pyz"
    },
    "entry_point": {
      "type": "string",
      "pattern": "^[a-z][a-z0-9_]*$",
      "description": "插件入口模块名，对应 src/ 下的模块目录名"
    },
    "dependencies": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "插件运行时依赖列表（PEP 508 格式）"
    }
  },
  "additionalProperties": false
}
