{
    // 使用 IntelliSense 了解相关属性   // 悬停以查看现有属性的描述。
    // 欲了解更多信息，请访问: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "初始化开发环境 (uv sync + init-dev)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/init_dev.py",
            "console": "integratedTerminal",
            "preLaunchTask": "uv sync"
        },
        {
            "name": "构建插件",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/build_plugin.py",
            "console": "integratedTerminal",
            "args": []
        },
        {
            "name": "构建插件（跳过依赖）",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/build_plugin.py",
            "console": "integratedTerminal",
            "args": [
                "--skip-deps"
            ]
        },
        {
            "name": "构建插件（不打包ZIP）",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/build_plugin.py",
            "console": "integratedTerminal",
            "args": [
                "--no-zip"
            ]
        },
        {
            "name": "下载依赖",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/download_wheels.py",
            "console": "integratedTerminal",
            "args": [
                "--platform",
                "win_amd64",
                "--python-version",
                "3.13",
                "--abi",
                "cp313"
            ]
        },
        {
            "name": "生成完整 CHANGELOG",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/generate_changelog.py",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env.local",
            "args": [
                "--output",
                "${workspaceFolder}/CHANGELOG.md"
            ]
        },
        {
            "name": "生成最新版本 CHANGELOG",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/generate_changelog.py",
            "console": "integratedTerminal",
            "envFile": "${workspaceFolder}/.env.local",
            "args": [
                "--latest"
            ]
        },
        {
            "name": "Python 调试程序: 当前文件",
            "type": "debugpy",
            "request": "launch",
            "program": "${file}",
            "console": "integratedTerminal",
            "env": {
                "PYTHONPATH": "${workspaceFolder}"
            }
        }
    ]
}
